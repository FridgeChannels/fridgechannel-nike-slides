PORT=4173

# Notion integration token (https://www.notion.so/profile/integrations).
# REQUIRED. Must start with `ntn_` (or `secret_` on legacy integrations).
NOTION_TOKEN=replace_with_your_notion_integration_token

# 2025-09-03 API: query a database via its data source id.
# Preferred. Get this from Notion: open the database -> ... menu ->
# Manage data sources -> Copy data source ID.
NOTION_DATA_SOURCE_ID=4a395356-7ecc-4587-80e0-670de9bf9834

# Legacy / discovery fallback. If NOTION_DATA_SOURCE_ID is empty, the server
# calls GET /v1/databases/{id} and uses the first data source it finds.
NOTION_DATABASE_ID=3599166fd9fd80a580a8c2b830e01c6f
